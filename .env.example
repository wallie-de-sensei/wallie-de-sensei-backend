# ============================================
# Wallie de Sensei Backend - Environment Configuration
# ============================================
# Copy this file to .env and update with your values
# NEVER commit .env to version control
# See README.md for detailed setup instructions

# ============================================
# Server Configuration
# ============================================
# NODE_ENV: Set to 'development' for local dev, 'production' for deployment
NODE_ENV=development

# PORT: HTTP server port (default: 3000)
PORT=3000

# LOG_LEVEL: Logging verbosity - options: error, warn, info, debug, verbose
LOG_LEVEL=info

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# Ensure PostgreSQL >= 14 is installed and running
# Create database before first run: CREATE DATABASE mentorsmind;
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=mentorsmind

# DB_LOGGING: Enable TypeORM query logging (useful for debugging)
DB_LOGGING=false

# ============================================
# Redis Configuration
# ============================================
# Optional - falls back to in-memory cache if not provided
# Redis provides better performance for caching and rate limiting
# Install Redis >= 6 for production deployments
USE_REDIS=false
REDIS_URL=redis://localhost:6379

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Change JWT_SECRET to a strong, random value in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT_EXPIRES_IN: Token expiration time (examples: 1h, 7d, 30d)
JWT_EXPIRES_IN=7d

# ============================================
# CORS Configuration
# ============================================
# CORS_ORIGIN: Allowed origins for cross-origin requests
# For multiple origins, use comma-separated list: http://localhost:3000,http://localhost:3001
# Use * only for development (security risk in production)
CORS_ORIGIN=http://localhost:3000
